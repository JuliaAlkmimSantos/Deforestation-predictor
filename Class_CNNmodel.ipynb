class DeforestationCNNPipeline:

    def __init__(
        self,
        raster_path,
        shapefile_path,
        label_col,
        block_size=20000,
        batch_size=8,
        lr=1e-4,
        epochs=10,
        out_size=35,
        seed=42
    ):

        self.device = "cuda" if torch.cuda.is_available() else "cpu"
        self.label_col = label_col
        self.block_size = block_size
        self.batch_size = batch_size
        self.lr = lr
        self.epochs = epochs
        self.out_size = out_size
        self.seed = seed

        # Load raster
        self.raster = rasterio.open(raster_path)

        # Load shapefile
        self.gdf = gpd.read_file(shapefile_path)
        self.gdf = self.gdf.dropna(subset=[label_col])

        if self.gdf.crs != self.raster.crs:
            self.gdf = self.gdf.to_crs(self.raster.crs)

        self.model = None
        self.train_loader = None
        self.test_loader = None


     # ---------------------------------------------------
    # PATCH DATASET BUILDER
    # ---------------------------------------------------

    def _create_dataset(self, gdf_subset):

        raster = self.raster
        label_col = self.label_col
        out_size = self.out_size

        class PatchDataset(Dataset):

            def __init__(self, gdf):
                self.gdf = gdf.reset_index(drop=True)

            def __len__(self):
                return len(self.gdf)

            def __getitem__(self, idx):

                row = self.gdf.iloc[idx]
                geom = [mapping(row.geometry)]

                # Crop raster to polygon
                patch, _ = mask(raster, geom, crop=True)

                # Convert to float32
                patch = patch.astype("float32")

                # Convert to tensor
                patch_tensor = torch.tensor(patch)
                #patch_tensor = (patch_tensor - patch_tensor.mean()) / (patch_tensor.std() + 1e-6)

                # Resize to fixed size
                patch_tensor = F.interpolate(
                    patch_tensor.unsqueeze(0),
                    size=(out_size, out_size),
                    mode='bilinear',
                    align_corners=False
                ).squeeze(0)

                # Label
                label = float(row[label_col])
                label_tensor = torch.tensor(label, dtype=torch.float32)

                return patch_tensor, label_tensor

        return PatchDataset(gdf_subset)


    # ---------------------------------------------------
    # 1️⃣ Spatial Block Split
    # ---------------------------------------------------

    def spatial_split(self):

        gdf = self.gdf.copy()

        gdf_x = gdf['clon']
        gdf_y = gdf['clat']

        gdf["block_x"] = np.floor(
            gdf_x / (self.block_size / 111320)
        ).astype(int)

        gdf["block_y"] = np.floor(
            gdf_y / (self.block_size / 110540)
        ).astype(int)

        gdf["block_id"] = (
            gdf["block_x"].astype(str) + "_" +
            gdf["block_y"].astype(str)
        )

        unique_blocks = gdf["block_id"].unique()

        np.random.seed(self.seed)
        np.random.shuffle(unique_blocks)

        split_idx = int(0.8 * len(unique_blocks))

        train_blocks = unique_blocks[:split_idx]
        test_blocks = unique_blocks[split_idx:]

        train_gdf = gdf[gdf["block_id"].isin(train_blocks)].reset_index(drop=True)
        test_gdf = gdf[gdf["block_id"].isin(test_blocks)].reset_index(drop=True)

        train_ds = self._create_dataset(train_gdf)
        test_ds = self._create_dataset(test_gdf)

        self.train_loader = DataLoader(train_ds, batch_size=self.batch_size, shuffle=True)
        self.test_loader = DataLoader(test_ds, batch_size=self.batch_size, shuffle=False)

        print("Train samples:", len(train_ds))
        print("Test samples:", len(test_ds))

        return self.train_loader, self.test_loader

    # ---------------------------------------------------
    # 2️⃣ Model Builder
    # ---------------------------------------------------

    def build_model(self):

        model = models.resnet18(weights=None)

        model.conv1 = nn.Conv2d(
            self.raster.count,
            64,
            kernel_size=7,
            stride=2,
            padding=3,
            bias=False
        )

        model.fc = nn.Linear(512, 1)

        self.model = model.to(self.device)

    # ---------------------------------------------------
    # 3️⃣ Training
    # ---------------------------------------------------

    def train(self):

        criterion = nn.BCEWithLogitsLoss()
        optimizer = torch.optim.Adam(self.model.parameters(), lr=self.lr)

        for epoch in range(self.epochs):

            self.model.train()
            epoch_loss = 0

            for patches, labels in tqdm(self.train_loader):

                patches = patches.to(self.device)
                labels = labels.to(self.device)

                optimizer.zero_grad()

                outputs = self.model(patches).flatten()
                loss = criterion(outputs, labels)

                loss.backward()
                optimizer.step()

                epoch_loss += loss.item()

            print(f"Epoch {epoch+1}/{self.epochs}, Loss = {epoch_loss/len(self.train_loader):.4f}")

    def load_model(self, path):

        self.model = torch.load(path, map_location=self.device)
        self.model.to(self.device)


        print("Model loaded from:", path)

    # ---------------------------------------------------
    # 4️⃣ Evaluation
    # ---------------------------------------------------

    def evaluate(self):

        from sklearn.metrics import (
            roc_auc_score,
            accuracy_score,
            confusion_matrix,
            classification_report,
            roc_curve
        )

        self.model.eval()

        all_probs = []
        all_labels = []

        with torch.no_grad():
            for patches, labels in tqdm(self.test_loader):

                patches = patches.to(self.device)
                labels = labels.to(self.device)

                outputs = self.model(patches).flatten()
                probs = torch.sigmoid(outputs)

                all_probs.extend(probs.cpu().numpy())
                all_labels.extend(labels.cpu().numpy())

        all_probs = np.array(all_probs)
        all_labels = np.array(all_labels)

        # -----------------------------
        # 1️⃣ Compute AUC correctly
        # -----------------------------
        auc = roc_auc_score(all_labels, all_probs)

        # -----------------------------
        # 2️⃣ Find best threshold (Youden J)
        # -----------------------------
        fpr, tpr, thresholds = roc_curve(all_labels, all_probs)
        youden = tpr - fpr
        best_idx = np.argmax(youden)
        best_threshold = thresholds[best_idx]

        # Predictions with optimal threshold
        best_preds = (all_probs > best_threshold).astype(float)

        best_acc = accuracy_score(all_labels, best_preds)

        # Also compute default 0.5 threshold for comparison
        default_preds = (all_probs > 0.5).astype(float)
        default_acc = accuracy_score(all_labels, default_preds)

        print("\n========== MODEL EVALUATION ==========")
        print("AUC:", auc)

        print("\n--- Threshold Comparison ---")
        print("Default threshold (0.5) accuracy:", default_acc)
        print("Optimal threshold:", best_threshold)
        print("Accuracy with optimal threshold:", best_acc)

        print("\nConfusion Matrix (Optimal Threshold):")
        print(confusion_matrix(all_labels, best_preds))

        print("\nClassification Report (Optimal Threshold):")
        print(classification_report(
            all_labels,
            best_preds,
            target_names=['No deforestation', 'Deforestation']
        ))

        print("=======================================\n")

        return best_threshold

    # ---------------------------------------------------
    # 5️⃣ Save Model
    # ---------------------------------------------------

    def save_model(self, path):

        torch.save(self.model, path)
        print("Model saved to:", path)







'''
Functions to produce visualizations
'''


def plot_confusion_matrix_pytorch(model_path, test_loader, device="cpu", threshold=0.5):
    """
    Plots confusion matrix for a PyTorch model using a DataLoader.
    threshold: probability cutoff for positive class
    """

    model = torch.load(model_path, map_location=device, weights_only=False)
    model.eval()

    all_probs = []
    all_labels = []

    with torch.no_grad():
        for inputs, labels in test_loader:

            inputs = inputs.to(device)
            labels = labels.to(device)

            outputs = model(inputs)

            # If using BCEWithLogitsLoss → apply sigmoid
            probs = torch.sigmoid(outputs)

            all_probs.append(probs.cpu().numpy())
            all_labels.append(labels.cpu().numpy())

    y_proba = np.concatenate(all_probs).ravel()
    y_true = np.concatenate(all_labels).ravel()

    # Convert probabilities to binary predictions
    y_pred = (y_proba >= threshold).astype(int)

    # Compute confusion matrix
    cm = confusion_matrix(y_true, y_pred)

    plt.figure()
    sns.heatmap(cm, annot=True, fmt="d", cmap="Blues",
                xticklabels=["No Deforestation", "Deforestation"],
                yticklabels=["No Deforestation", "Deforestation"])
    plt.xlabel("Predicted")
    plt.ylabel("Actual")
    plt.title(f"Confusion Matrix (threshold = {threshold})")
    plt.show()

    return cm

def plot_roc_curve_pytorch(model_path, test_loader, device="cpu"):
    """
    Plots ROC curve and computes best threshold using Youden's J statistic.
    Returns:
        roc_auc, best_threshold
    """

    model = torch.load(model_path, map_location=device, weights_only=False)
    model.eval()

    all_probs = []
    all_labels = []

    with torch.no_grad():
        for inputs, labels in test_loader:

            inputs = inputs.to(device)
            labels = labels.to(device)

            outputs = model(inputs)

            # If using BCEWithLogitsLoss
            probs = torch.sigmoid(outputs)

            all_probs.append(probs.cpu().numpy())
            all_labels.append(labels.cpu().numpy())

    y_proba = np.concatenate(all_probs).ravel()
    y_true = np.concatenate(all_labels).ravel()

    # 🔹 Compute ROC
    fpr, tpr, thresholds = roc_curve(y_true, y_proba)
    roc_auc = auc(fpr, tpr)

    # 🔹 Compute Youden’s J statistic
    youden_j = tpr - fpr
    best_index = np.argmax(youden_j)
    best_threshold = thresholds[best_index]

    print(f"Best threshold (Youden’s J): {best_threshold:.4f}")
    print(f"AUC: {roc_auc:.4f}")

    # 🔹 Plot ROC
    plt.figure()
    plt.plot(fpr, tpr, label=f"AUC = {roc_auc:.3f}")
    plt.scatter(fpr[best_index], tpr[best_index],
                label=f"Best threshold = {best_threshold:.3f}",
                marker='o')
    plt.plot([0, 1], [0, 1], linestyle="--")
    plt.xlabel("False Positive Rate")
    plt.ylabel("True Positive Rate")
    plt.title("ROC Curve")
    plt.legend()
    plt.show()

    return roc_auc, best_threshold




def plot_pr_curve_pytorch(model_path, test_loader, device="cpu"):
    """
    Plots Precision-Recall curve for a PyTorch model using a DataLoader.
    """

    model = torch.load(model_path, map_location=device, weights_only=False)
    model.eval()

    all_probs = []
    all_labels = []

    with torch.no_grad():
        for batch in test_loader:

            inputs, labels = batch
            inputs = inputs.to(device)
            labels = labels.to(device)

            outputs = model(inputs)

            # If using BCEWithLogitsLoss → apply sigmoid
            probs = torch.sigmoid(outputs)

            all_probs.append(probs.cpu().numpy())
            all_labels.append(labels.cpu().numpy())

    y_proba = np.concatenate(all_probs).ravel()
    y_true = np.concatenate(all_labels).ravel()

    precision, recall, _ = precision_recall_curve(y_true, y_proba)
    avg_precision = average_precision_score(y_true, y_proba)

    plt.figure()
    plt.plot(recall, precision, label=f"AP = {avg_precision:.3f}")
    plt.xlabel("Recall")
    plt.ylabel("Precision")
    plt.title("Precision-Recall Curve")
    plt.legend()
    plt.show()

    return avg_precision





class DeforestationPredictor:

    def __init__(
        self,
        raster_path,
        shapefile_path,
        model_path,
        out_size=35,
        batch_size=8,
        threshold=0.5
    ):

        self.device = "cuda" if torch.cuda.is_available() else "cpu"
        self.out_size = out_size
        self.batch_size = batch_size
        self.threshold = threshold

        # Load raster
        self.raster = rasterio.open(raster_path)

        # Load shapefile
        self.gdf = gpd.read_file(shapefile_path)

        # Reproject if necessary
        if self.gdf.crs != self.raster.crs:
            self.gdf = self.gdf.to_crs(self.raster.crs)

        # Load model
        self.model = torch.load(
            model_path,
            map_location=self.device,
            weights_only=False
        )

        self.model.eval()
        self.model.to(self.device)

        print("Model loaded successfully.")

    # ---------------------------------------------------
    # Dataset Builder (no labels)
    # ---------------------------------------------------

    def _create_dataset(self):

        raster = self.raster
        out_size = self.out_size

        class InferenceDataset(Dataset):

            def __init__(self, gdf):
                self.gdf = gdf.reset_index(drop=True)

            def __len__(self):
                return len(self.gdf)

            def __getitem__(self, idx):

                row = self.gdf.iloc[idx]
                geom = [mapping(row.geometry)]

                patch, _ = mask(raster, geom, crop=True)

                patch = patch.astype("float32")
                patch = torch.tensor(patch)

                patch = F.interpolate(
                    patch.unsqueeze(0),
                    size=(out_size, out_size),
                    mode='bilinear',
                    align_corners=False
                ).squeeze(0)

                return patch

        return InferenceDataset(self.gdf)

    # ---------------------------------------------------
    # Run Inference
    # ---------------------------------------------------

    def run_inference(self):

        dataset = self._create_dataset()

        loader = DataLoader(
            dataset,
            batch_size=self.batch_size,
            shuffle=False
        )

        all_probs = []
        all_preds = []

        with torch.no_grad():
            for patches in loader:

                patches = patches.to(self.device)

                logits = self.model(patches).flatten()
                probs = torch.sigmoid(logits)

                preds = (probs >= self.threshold).long()

                all_probs.extend(probs.cpu().numpy())
                all_preds.extend(preds.cpu().numpy())

        self.gdf["prob_deforestation"] = all_probs
        self.gdf["pred_deforestation"] = all_preds

        print("Inference complete.")
        return self.gdf

    # ---------------------------------------------------
    # Save Results
    # ---------------------------------------------------

    def save_results(self, output_dir, prefix="predicted_deforestation"):

        os.makedirs(output_dir, exist_ok=True)

        geojson_path = os.path.join(output_dir, prefix + ".geojson")
        shp_path = os.path.join(output_dir, prefix + ".shp")
        csv_path = os.path.join(output_dir, prefix + ".csv")

        self.gdf.to_file(geojson_path, driver="GeoJSON")
        print("Saved GeoJSON:", geojson_path)

        self.gdf.to_file(shp_path, driver="ESRI Shapefile")
        print("Saved Shapefile:", shp_path)

