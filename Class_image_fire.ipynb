class VariableDiagnosticAnalysis:
    """
    Diagnostic analysis showing how predictor variables behave
    differently across cell categories (persistent, new predicted,
    new missed, true negatives).
    """

    def __init__(
    self,
    predictions_path,
    raster_path,
    truth_2022_path=None,
    truth_2023_path=None,
    defor_current_col="defor_2022",
    defor_future_col="defor_2023",
    pred_col="pred_defor",
    bands_per_variable=22,
    num_variables=3,
    variable_names=None,
    year_range=(2001, 2023),
    max_samples=100
):
        preds = gpd.read_file(predictions_path)
        print(f"Predictions columns: {preds.columns.tolist()}")

        # ALWAYS use external truth files if provided
        if truth_2022_path is not None:
            truth_2022 = gpd.read_file(truth_2022_path)
            if defor_current_col in preds.columns:
                preds = preds.drop(columns=[defor_current_col])
            preds = preds.merge(
                truth_2022[['grid_id', defor_current_col]],
                on='grid_id', how='inner'
            )
            print(f"Merged {defor_current_col} from truth_2022_path ({len(preds)} cells)")
        elif defor_current_col not in preds.columns:
            raise ValueError(f"'{defor_current_col}' not in predictions. Provide truth_2022_path.")

        if truth_2023_path is not None:
            truth_2023 = gpd.read_file(truth_2023_path)
            if defor_future_col in preds.columns:
                preds = preds.drop(columns=[defor_future_col])
            preds = preds.merge(
                truth_2023[['grid_id', defor_future_col]],
                on='grid_id', how='inner'
            )
            print(f"Merged {defor_future_col} from truth_2023_path ({len(preds)} cells)")
        elif defor_future_col not in preds.columns:
            raise ValueError(f"'{defor_future_col}' not in predictions. Provide truth_2023_path.")

        preds = preds.dropna(subset=[defor_current_col, defor_future_col])
        self.gdf = preds

        self.raster = rasterio.open(raster_path)
        self.defor_current = defor_current_col
        self.defor_future = defor_future_col
        self.pred_col = pred_col
        self.bands_per_variable = bands_per_variable
        self.num_variables = num_variables
        self.years = list(range(year_range[0], year_range[1]))
        self.max_samples = max_samples

        if variable_names is None:
            self.variable_names = [f"Variable {v}" for v in range(num_variables)]
        else:
            self.variable_names = variable_names

        print(f"Total cells: {len(self.gdf)}")

        self.categories = self._categorize_cells()
        self.profiles = self._extract_all_profiles()

    # ---------------------------------------------------
    # CATEGORIZE CELLS
    # ---------------------------------------------------

    def _categorize_cells(self):

        m = self.gdf

        categories = {
            "Persistent (correct)": (
                m[(m[self.defor_current] == 1) &
                  (m[self.defor_future] == 1) &
                  (m[self.pred_col] == 1)],
                "gold"
            ),
            "New (predicted)": (
                m[(m[self.defor_current] == 0) &
                  (m[self.defor_future] == 1) &
                  (m[self.pred_col] == 1)],
                "green"
            ),
            "New (missed)": (
                m[(m[self.defor_current] == 0) &
                  (m[self.defor_future] == 1) &
                  (m[self.pred_col] == 0)],
                "red"
            ),
            "True negatives": (
                m[(m[self.defor_current] == 0) &
                  (m[self.defor_future] == 0) &
                  (m[self.pred_col] == 0)],
                "blue"
            )
        }

        print("Cell categories:")
        for label, (df, _) in categories.items():
            print(f"  {label}: {len(df)} cells")

        return categories

    # ---------------------------------------------------
    # EXTRACT VARIABLE PROFILES
    # ---------------------------------------------------

    def _extract_profile(self, gdf_subset):
        """
        For each cell, extract mean distance per variable per year.
        Returns dict of {variable_name: array (num_cells, num_years)}
        """
        profiles = {name: [] for name in self.variable_names}

        sample = gdf_subset.head(self.max_samples)

        for _, row in sample.iterrows():
            geom = [mapping(row.geometry)]
            try:
                patch, _ = mask(self.raster, geom, crop=True)
                patch = patch.astype("float32")

                for v, name in enumerate(self.variable_names):
                    yearly_means = []
                    for t in range(self.bands_per_variable):
                        band_idx = v * self.bands_per_variable + t
                        yearly_means.append(patch[band_idx].mean())
                    profiles[name].append(yearly_means)
            except:
                continue

        for name in profiles:
            profiles[name] = np.array(profiles[name])

        return profiles

    def _extract_all_profiles(self):
        """
        Extracts profiles for all categories.
        """
        all_profiles = {}

        for label, (cat_df, color) in self.categories.items():
            if len(cat_df) > 0:
                print(f"Extracting profiles: {label} ({min(len(cat_df), self.max_samples)} cells)...")
                all_profiles[label] = self._extract_profile(cat_df)
            else:
                all_profiles[label] = {name: np.array([]) for name in self.variable_names}

        return all_profiles

    # ---------------------------------------------------
    # PLOT 1: TEMPORAL PROFILES
    # ---------------------------------------------------
    def print_rate_summary(self):
        """
        Compares recent rate of change (last 5 years) versus
        early rate of change (first 5 years) for each category.
        """
        print(f"\n{'='*60}")
        print("RATE OF CHANGE COMPARISON")
        print(f"{'='*60}")

        for label in self.categories:
            print(f"\n{label}:")
            for var_name in self.variable_names:
                prof = self.profiles[label][var_name]
                if len(prof) > 0:
                    yearly_means = prof.mean(axis=0)

                    # Early rate: mean year-over-year change in first 5 years
                    early_deltas = np.diff(yearly_means[:6])
                    early_rate = early_deltas.mean()

                    # Recent rate: mean year-over-year change in last 5 years
                    recent_deltas = np.diff(yearly_means[-6:])
                    recent_rate = recent_deltas.mean()

                    # Overall rate
                    overall_rate = np.diff(yearly_means).mean()

                    print(f"  {var_name}:")
                    print(f"    First 5y:  {early_rate:.2f} per year")
                    print(f"    Last 5y:  {recent_rate:.2f} per year")
                    print(f"    Overall rate: {overall_rate:.2f} per year")
                    print(f"    Accelerating: {'Yes' if abs(recent_rate) > abs(early_rate) else 'No'}")

        print(f"\n{'='*60}\n")

    def plot_temporal_profiles(self):
        """
        Shows how each variable's mean distance evolves over time
        for each cell category.
        """
        fig, axes = plt.subplots(1, self.num_variables, figsize=(6 * self.num_variables, 5))

        if self.num_variables == 1:
            axes = [axes]

        for i, var_name in enumerate(self.variable_names):
            ax = axes[i]

            for label, (_, color) in self.categories.items():
                prof = self.profiles[label][var_name]
                if len(prof) > 0:
                    ax.plot(self.years, prof.mean(axis=0),
                            label=f"{label} (n={len(prof)})",
                            color=color, linewidth=2)

            ax.set_title(var_name)
            ax.set_xlabel("Year")
            ax.set_ylabel("Mean Distance in Pixels (30m)")
            ax.legend(fontsize=8)

        plt.suptitle("Temporal Profile of Predictor Variables by Cell Category", fontsize=14)
        plt.tight_layout()
        plt.show()

    # ---------------------------------------------------
    # PLOT 2: FINAL YEAR BOXPLOTS
    # ---------------------------------------------------

    def plot_final_year_distances(self):
        """
        Boxplot of each variable's distance in the last year of input,
        compared across cell categories.
        """
        fig, axes = plt.subplots(1, self.num_variables, figsize=(6 * self.num_variables, 5))

        if self.num_variables == 1:
            axes = [axes]

        for i, var_name in enumerate(self.variable_names):
            ax = axes[i]
            data = []
            labels = []

            for label, (_, color) in self.categories.items():
                prof = self.profiles[label][var_name]
                if len(prof) > 0:
                    last_year_vals = prof[:, -1]
                    data.append(last_year_vals)
                    labels.append(label)

            ax.boxplot(data, labels=labels)
            ax.set_title(var_name)
            ax.set_ylabel("Distance (last year)")
            ax.tick_params(axis='x', rotation=15)

        plt.suptitle("Final-Year Distance Distribution by Cell Category", fontsize=14)
        plt.tight_layout()
        plt.show()

    # ---------------------------------------------------
    # PLOT 3: RATE OF CHANGE
    # ---------------------------------------------------

    def plot_rate_of_change(self):
        """
        Year-over-year change in distance for each variable.
        Negative values = variable approaching the cell.
        """
        colors = {}
        for label, (_, color) in self.categories.items():
            colors[label] = color

        fig, axes = plt.subplots(1, self.num_variables, figsize=(6 * self.num_variables, 5))

        if self.num_variables == 1:
            axes = [axes]

        for i, var_name in enumerate(self.variable_names):
            ax = axes[i]

            for label in self.categories:
                prof = self.profiles[label][var_name]
                if len(prof) > 0:
                    yearly_vals = prof.mean(axis=0)
                    deltas = np.diff(yearly_vals)
                    ax.plot(self.years[1:], deltas,
                            label=f"{label}",
                            color=colors[label], linewidth=2)

            ax.axhline(y=0, color='gray', linestyle='--', alpha=0.5)
            ax.set_title(var_name)
            ax.set_xlabel("Year")
            ax.set_ylabel("Year-over-Year Change")
            ax.legend(fontsize=8)

        plt.suptitle("Rate of Change in Predictor Variables by Cell Category", fontsize=14)
        plt.tight_layout()
        plt.show()

    # ---------------------------------------------------
    # PRINT SUMMARY
    # ---------------------------------------------------

    def print_summary(self):
        """
        Prints mean first-year and last-year distances per category.
        """
        print(f"\n{'='*60}")
        print("VARIABLE DIAGNOSTIC SUMMARY")
        print(f"{'='*60}")

        for label in self.categories:
            print(f"\n{label}:")
            for var_name in self.variable_names:
                prof = self.profiles[label][var_name]
                if len(prof) > 0:
                    first_year = prof[:, 0].mean()
                    last_year = prof[:, -1].mean()
                    total_change = last_year - first_year
                    print(f"  {var_name}:")
                    print(f"    First year mean: {first_year:.2f}")
                    print(f"    Last year mean:  {last_year:.2f}")
                    print(f"    Total change:    {total_change:.2f}")

        print(f"\n{'='*60}\n")

    # ---------------------------------------------------
    # RUN ALL
    # ---------------------------------------------------

    def run_full_analysis(self):
        """
        Runs all diagnostic plots and prints summary.
        """
        self.print_summary()
        self.plot_temporal_profiles()
        self.plot_final_year_distances()
        self.plot_rate_of_change()






class FireDiagnosticAnalysis:
    """
    Diagnostic analysis to show that missed deforestation cells
    had fire activity the model couldn't see.
    """

    def __init__(
    self,
    predictions_path,
    fire_counts_path,
    truth_2022_path=None,
    truth_2023_path=None,
    defor_current_col="defor_2022",
    defor_future_col="defor_2023",
    pred_col="pred_defor",
    prob_col="prob_defor",
    year_range=(2001, 2023)
):
        # Load predictions
        preds = gpd.read_file(predictions_path)
        print(f"Predictions columns: {preds.columns.tolist()}")

        # Check what's missing and merge only what's needed

        if truth_2022_path is not None:
            truth_2022 = gpd.read_file(truth_2022_path)
            if defor_current_col in preds.columns:
                preds = preds.drop(columns=[defor_current_col])
            preds = preds.merge(
                truth_2022[['grid_id', defor_current_col]],
                on='grid_id', how='inner'  # inner join like EE
            )
            print(f"Merged {defor_current_col} from truth_2022_path ({len(preds)} cells after join)")
        elif defor_current_col not in preds.columns:
            raise ValueError(f"'{defor_current_col}' not in predictions. Provide truth_2022_path.")

        if truth_2023_path is not None:
            truth_2023 = gpd.read_file(truth_2023_path)
            if defor_future_col in preds.columns:
                preds = preds.drop(columns=[defor_future_col])
            preds = preds.merge(
                truth_2023[['grid_id', defor_future_col]],
                on='grid_id', how='inner'  # inner join like EE
            )
            print(f"Merged {defor_future_col} from truth_2023_path ({len(preds)} cells after join)")
        elif defor_future_col not in preds.columns:
            raise ValueError(f"'{defor_future_col}' not in predictions. Provide truth_2023_path.")

        # --- CLEAN DEFOR NULLS IN PREDICTIONS ---


        preds = preds.dropna(subset=[defor_current_col, defor_future_col])

        self.gdf = preds

        # Load fire counts
        self.fire_df = pd.read_csv(fire_counts_path)

        self.defor_current = defor_current_col
        self.defor_future = defor_future_col
        self.pred_col = pred_col
        self.prob_col = prob_col
        self.years = list(range(year_range[0], year_range[1]))
        self.fire_cols = [f'fire_{y}' for y in self.years]

        # Merge fire data
        self.merged = self.gdf.merge(
            self.fire_df[['grid_id'] + self.fire_cols],
            on='grid_id', how='left'
        )
        self.merged[self.fire_cols] = self.merged[self.fire_cols].fillna(0)

        # Verify
        print(f"\nTotal cells: {len(self.merged)}")
        print(f"Cells with {defor_current_col}: {self.merged[defor_current_col].notna().sum()}")
        print(f"Cells with {defor_future_col}: {self.merged[defor_future_col].notna().sum()}")
        print(f"Cells with fire data: {(self.merged[self.fire_cols].sum(axis=1) > 0).sum()}")

        # Categorize cells
        self.categories = self._categorize_cells()

    # ---------------------------------------------------
    # CATEGORIZE CELLS
    # ---------------------------------------------------

    def _categorize_cells(self):

        m = self.merged

        persistent_correct = m[
            (m[self.defor_current] == 1) &
            (m[self.defor_future] == 1) &
            (m[self.pred_col] == 1)
        ]

        new_predicted = m[
            (m[self.defor_current] == 0) &
            (m[self.defor_future] == 1) &
            (m[self.pred_col] == 1)
        ]

        new_missed = m[
            (m[self.defor_current] == 0) &
            (m[self.defor_future] == 1) &
            (m[self.pred_col] == 0)
        ]

        true_negatives = m[
            (m[self.defor_current] == 0) &
            (m[self.defor_future] == 0) &
            (m[self.pred_col] == 0)
        ]

        categories = {
            "Persistent (correct)": (persistent_correct, "gold"),
            "New (predicted)": (new_predicted, "green"),
            "New (missed)": (new_missed, "red"),
            "True negatives": (true_negatives, "blue")
        }

        print("Cell categories:")
        for label, (df, _) in categories.items():
            print(f"  {label}: {len(df)} cells")

        return categories

    # ---------------------------------------------------
    # PLOT 1: FIRE OVER TIME
    # ---------------------------------------------------

    def plot_fire_over_time(self):
        """
        Shows mean fire detections per cell per year for each category.
        Reveals whether missed cells had increasing fire before deforestation.
        """

        fig, ax = plt.subplots(figsize=(12, 6))

        for label, (cat_df, color) in self.categories.items():
            if len(cat_df) > 0:
                means = cat_df[self.fire_cols].mean()
                ax.plot(self.years, means.values,
                        label=f"{label} (n={len(cat_df)})",
                        color=color, linewidth=2)

        ax.set_xlabel("Year")
        ax.set_ylabel("Mean Burned Pixels per Cell (30m)")
        ax.set_title("Fire Scar Activity Over Time by Cell Category")
        ax.legend()
        plt.tight_layout()
        plt.show()

    # ---------------------------------------------------
    # PLOT 2: RECENT FIRE (3 YEARS BEFORE)
    # ---------------------------------------------------

    def plot_recent_fire(self, lookback=3):
        """
        Boxplot of fire activity in the years immediately before
        the deforestation classification year.
        """

        recent_cols = self.fire_cols[-lookback:]
        recent_years = self.years[-lookback:]

        fig, ax = plt.subplots(figsize=(10, 6))

        data = []
        labels = []

        for label, (cat_df, color) in self.categories.items():
            if len(cat_df) > 0:
                total_recent = cat_df[recent_cols].sum(axis=1)
                data.append(total_recent.values)
                labels.append(label)

        ax.boxplot(data, labels=labels)
        ax.set_ylabel(f"Total Burned Pixels ({recent_years[0]}-{recent_years[-1]})")
        ax.set_title(f"Fire Scars in the {lookback} Years Before Deforestation Classification")
        plt.tight_layout()
        plt.show()

    # ---------------------------------------------------
    # PLOT 3: PERCENTAGE WITH ANY FIRE
    # ---------------------------------------------------

    def plot_fire_percentage(self, lookback=3):
        """
        Bar chart showing what percentage of cells in each category
        had any fire activity in the recent period.
        """

        recent_cols = self.fire_cols[-lookback:]
        recent_years = self.years[-lookback:]

        fig, ax = plt.subplots(figsize=(8, 5))

        cat_labels = []
        pct_values = []
        bar_colors = []

        for label, (cat_df, color) in self.categories.items():
            if len(cat_df) > 0:
                had_fire = (cat_df[recent_cols].sum(axis=1) > 0).mean() * 100
                cat_labels.append(label)
                pct_values.append(had_fire)
                bar_colors.append(color)

        ax.bar(cat_labels, pct_values, color=bar_colors)
        ax.set_ylabel(f"% of Cells with Fire ({recent_years[0]}-{recent_years[-1]})")
        ax.set_title("Proportion of Cells with Pre-Deforestation Fire Activity")
        plt.tight_layout()
        plt.show()

    # ---------------------------------------------------
    # PLOT 4: CUMULATIVE FIRE HISTORY
    # ---------------------------------------------------

    def plot_cumulative_fire(self):
        """
        Cumulative fire over all years, showing total fire exposure
        per category. Reveals long-term degradation patterns.
        """

        fig, ax = plt.subplots(figsize=(12, 6))

        for label, (cat_df, color) in self.categories.items():
            if len(cat_df) > 0:
                cumulative = cat_df[self.fire_cols].mean().cumsum()
                ax.plot(self.years, cumulative.values,
                        label=f"{label} (n={len(cat_df)})",
                        color=color, linewidth=2)

        ax.set_xlabel("Year")
        ax.set_ylabel("Cumulative Mean Burned Pixels per Cell")
        ax.set_title("Cumulative Fire Exposure by Cell Category")
        ax.legend()
        plt.tight_layout()
        plt.show()

    def plot_fire_over_time_zoomed(self):
        """
        Same plot but excluding persistent cells to show
        the difference between missed and true negatives.
        """
        fig, ax = plt.subplots(figsize=(12, 6))

        for label, (cat_df, color) in self.categories.items():
            if label == "Persistent (correct)":
                continue  # skip to fix the scale
            if len(cat_df) > 0:
                means = cat_df[self.fire_cols].mean()
                ax.plot(self.years, means.values,
                        label=f"{label} (n={len(cat_df)})",
                        color=color, linewidth=2)

        ax.set_xlabel("Year")
        ax.set_ylabel("Mean Burned Pixels per Cell (30m)")
        ax.set_title("Fire Scar Activity: New Deforestation vs True Negatives")
        ax.legend()
        plt.tight_layout()
        plt.show()

    # ---------------------------------------------------
    # PRINT SUMMARY STATISTICS
    # ---------------------------------------------------

    def print_summary(self, lookback=3):
        """
        Prints fire statistics for each category.
        """

        recent_cols = self.fire_cols[-lookback:]
        recent_years = self.years[-lookback:]

        print(f"\n{'='*60}")
        print(f"FIRE DIAGNOSTIC SUMMARY ({recent_years[0]}-{recent_years[-1]})")
        print(f"{'='*60}")

        for label, (cat_df, color) in self.categories.items():
            if len(cat_df) > 0:
                recent_total = cat_df[recent_cols].sum(axis=1)
                all_total = cat_df[self.fire_cols].sum(axis=1)

                pct_recent = (recent_total > 0).mean() * 100
                pct_ever = (all_total > 0).mean() * 100
                mean_recent = recent_total.mean()
                mean_all = all_total.mean()

                print(f"\n{label} ({len(cat_df)} cells):")
                print(f"  Recent fire ({recent_years[0]}-{recent_years[-1]}):")
                print(f"    {pct_recent:.1f}% had fire")
                print(f"    Mean burned pixels: {mean_recent:.1f}")
                print(f"  All years ({self.years[0]}-{self.years[-1]}):")
                print(f"    {pct_ever:.1f}% had fire at any point")
                print(f"    Mean total burned pixels: {mean_all:.1f}")

        print(f"\n{'='*60}\n")

    # ---------------------------------------------------
    # RUN ALL
    # ---------------------------------------------------

    def run_full_analysis(self, lookback=3):
        """
        Runs all diagnostic plots and prints summary.
        """

        self.print_summary(lookback=lookback)
        self.plot_fire_over_time()
        self.plot_recent_fire(lookback=lookback)
        self.plot_fire_percentage(lookback=lookback)
        self.plot_cumulative_fire()
