class CNN_LSTM(nn.Module):

    def __init__(self, bands_per_step, hidden_size=128, num_lstm_layers=2):
        super(CNN_LSTM, self).__init__()

        # CNN feature extractor — shared across all time steps
        # uses ResNet-18 backbone without the classification head
        resnet = models.resnet18(weights=None)
        resnet.conv1 = nn.Conv2d(
            bands_per_step, 64,
            kernel_size=7, stride=2, padding=3, bias=False
        )
        self.cnn = nn.Sequential(*list(resnet.children())[:-1])
        # output per time step: (batch, 512, 1, 1)

        # LSTM to learn temporal evolution of spatial features
        self.lstm = nn.LSTM(
            input_size=512,
            hidden_size=hidden_size,
            num_layers=num_lstm_layers,
            batch_first=True,
            dropout=0.3 if num_lstm_layers > 1 else 0.0
        )

        # Temporal attention — learns which years matter most
        self.attention = nn.Sequential(
            nn.Linear(hidden_size, 64),
            nn.Tanh(),
            nn.Linear(64, 1)
        )

        # Final classifier
        self.fc = nn.Sequential(
            nn.Linear(hidden_size, 64),
            nn.ReLU(),
            nn.Dropout(0.3),
            nn.Linear(64, 1)
        )

    def forward(self, x):
        # x shape: (batch, time_steps, bands_per_step, H, W)
        batch_size, time_steps, C, H, W = x.shape

        # Extract spatial features from each time step
        cnn_features = []
        for t in range(time_steps):
            feat = self.cnn(x[:, t, :, :, :])    # (batch, 512, 1, 1)
            feat = feat.view(batch_size, -1)       # (batch, 512)
            cnn_features.append(feat)

        # Stack into temporal sequence: (batch, time_steps, 512)
        cnn_features = torch.stack(cnn_features, dim=1)

        # Learn temporal patterns: (batch, time_steps, hidden_size)
        lstm_out, _ = self.lstm(cnn_features)

        # Attention weighting over time steps
        attn_weights = self.attention(lstm_out)              # (batch, time_steps, 1)
        attn_weights = torch.softmax(attn_weights, dim=1)   # normalize across time

        # Weighted sum of all time steps: (batch, hidden_size)
        context = torch.sum(lstm_out * attn_weights, dim=1)

        # Classify
        out = self.fc(context)
        return out





class DeforestationCNNPipeline:

    def __init__(self,
    raster_path,
    shapefile_path,
    label_col,
    model_type="resnet",        # NEW
    num_years=22,               # NEW
    bands_per_variable=22,      # NEW
    num_variables=3,            # NEW
    has_static_band=True,       # NEW
    hidden_size=128,            # NEW
    num_lstm_layers=2,          # NEW
    block_size=20000,
    batch_size=8,
    lr=1e-4,
    epochs=10,
    out_size=35,
    seed=42
):

        self.device = "cuda" if torch.cuda.is_available() else "cpu"
        self.label_col = label_col
        self.block_size = block_size
        self.batch_size = batch_size
        self.lr = lr
        self.epochs = epochs
        self.out_size = out_size
        self.seed = seed

        # Load raster
        self.raster = rasterio.open(raster_path)

        # Load shapefile
        self.gdf = gpd.read_file(shapefile_path)
        self.gdf = self.gdf.dropna(subset=[label_col])

        if self.gdf.crs != self.raster.crs:
            self.gdf = self.gdf.to_crs(self.raster.crs)

        self.model = None
        self.train_loader = None
        self.test_loader = None
        self.model_type = model_type
        self.num_years = num_years
        self.bands_per_variable = bands_per_variable
        self.num_variables = num_variables
        self.has_static_band = has_static_band
        self.hidden_size = hidden_size
        self.num_lstm_layers = num_lstm_layers
        self.bands_per_step = num_variables + (1 if has_static_band else 0)
        if self.model_type == "cnn_lstm_combined":
          self.bands_per_step = self.bands_per_step * 2


     # ---------------------------------------------------
    # PATCH DATASET BUILDER
    # ---------------------------------------------------

    def _create_dataset(self, gdf_subset):

        raster = self.raster
        label_col = self.label_col
        out_size = self.out_size

        # Making these pipeline attributes accessible within PatchDataset
        model_type = self.model_type
        num_years = self.num_years
        bands_per_variable = self.bands_per_variable
        num_variables = self.num_variables
        has_static_band = self.has_static_band

        class PatchDataset(Dataset):

            def __init__(self, gdf):
                self.gdf = gdf.reset_index(drop=True)

            def __len__(self):
                return len(self.gdf)

            def __getitem__(self, idx):

                row = self.gdf.iloc[idx]
                geom = [mapping(row.geometry)]

                # Crop raster to polygon
                patch, _ = mask(raster, geom, crop=True)

                # Convert to float32
                patch = patch.astype("float32")

                # Convert to tensor
                patch_tensor = torch.tensor(patch)
                #patch_tensor = (patch_tensor - patch_tensor.mean()) / (patch_tensor.std() + 1e-6)

                # Resize to fixed size
                patch_tensor = F.interpolate(
                    patch_tensor.unsqueeze(0),
                    size=(out_size, out_size),
                    mode='bilinear',
                    align_corners=False
                ).squeeze(0)

                # Label
                label = float(row[label_col])
                label_tensor = torch.tensor(label, dtype=torch.float32)

                # NEW: branch based on model type
                if model_type in ("cnn_lstm", "cnn_lstm_delta", "cnn_lstm_combined"):
                    time_steps = []
                    for t in range(num_years):
                        bands_for_year = []
                        for v in range(num_variables):
                            bands_for_year.append(patch_tensor[v * bands_per_variable + t])
                        if has_static_band:
                            bands_for_year.append(patch_tensor[-1])
                        time_steps.append(torch.stack(bands_for_year, dim=0))

                    sequence = torch.stack(time_steps, dim=0)

                    if model_type == "cnn_lstm_delta":
                        deltas = sequence[1:] - sequence[:-1]
                        return deltas, label_tensor

                    elif model_type == "cnn_lstm_combined":
                        # Compute deltas, pad first step with zeros
                        deltas = torch.zeros_like(sequence)
                        deltas[1:] = sequence[1:] - sequence[:-1]

                        # Concatenate raw + delta per time step
                        # shape goes from (T, bands, H, W) to (T, bands*2, H, W)
                        combined = torch.cat([sequence, deltas], dim=1)
                        return combined, label_tensor
                    else:
                        return sequence, label_tensor
                else:
                    return patch_tensor, label_tensor


        return PatchDataset(gdf_subset)


    # ---------------------------------------------------
    # 1️⃣ Spatial Block Split
    # ---------------------------------------------------

    def spatial_split(self):

        gdf = self.gdf.copy()

        gdf_x = gdf['clon']
        gdf_y = gdf['clat']

        gdf["block_x"] = np.floor(
            gdf_x / (self.block_size / 111320)
        ).astype(int)

        gdf["block_y"] = np.floor(
            gdf_y / (self.block_size / 110540)
        ).astype(int)

        gdf["block_id"] = (
            gdf["block_x"].astype(str) + "_" +
            gdf["block_y"].astype(str)
        )

        unique_blocks = gdf["block_id"].unique()

        np.random.seed(self.seed)
        np.random.shuffle(unique_blocks)

        split_idx = int(0.8 * len(unique_blocks))

        train_blocks = unique_blocks[:split_idx]
        test_blocks = unique_blocks[split_idx:]

        train_gdf = gdf[gdf["block_id"].isin(train_blocks)].reset_index(drop=True)
        test_gdf = gdf[gdf["block_id"].isin(test_blocks)].reset_index(drop=True)

        train_ds = self._create_dataset(train_gdf)
        test_ds = self._create_dataset(test_gdf)

        self.train_loader = DataLoader(train_ds, batch_size=self.batch_size, shuffle=True)
        self.test_loader = DataLoader(test_ds, batch_size=self.batch_size, shuffle=False)

        print("Train samples:", len(train_ds))
        print("Test samples:", len(test_ds))

        return self.train_loader, self.test_loader

    # ---------------------------------------------------
    # 2️⃣ Model Builder
    # ---------------------------------------------------

    def build_model(self):

        if self.model_type in ("cnn_lstm", "cnn_lstm_delta", "cnn_lstm_combined"):
          self.model = CNN_LSTM(
              bands_per_step=self.bands_per_step,
              hidden_size=self.hidden_size,
              num_lstm_layers=self.num_lstm_layers
          ).to(self.device)
        else:
            model = models.resnet18(weights=None)
            model.conv1 = nn.Conv2d(
                self.raster.count, 64,
                kernel_size=7, stride=2, padding=3, bias=False
            )
            model.fc = nn.Linear(512, 1)
            self.model = model.to(self.device)




    # ---------------------------------------------------
    # 3️⃣ Training
    # ---------------------------------------------------

    def train(self, checkpoint_dir=None):

        criterion = nn.BCEWithLogitsLoss()
        optimizer = torch.optim.Adam(self.model.parameters(), lr=self.lr)

        start_epoch = 0

        # Resume from checkpoint if it exists
        if checkpoint_dir:
            os.makedirs(checkpoint_dir, exist_ok=True)
            checkpoint_path = os.path.join(checkpoint_dir, "latest_checkpoint.pth")

            if os.path.exists(checkpoint_path):
                checkpoint = torch.load(checkpoint_path, map_location=self.device)
                self.model.load_state_dict(checkpoint['model_state'])
                optimizer.load_state_dict(checkpoint['optimizer_state'])
                start_epoch = checkpoint['epoch'] + 1
                print(f"Resumed from epoch {start_epoch}")

        for epoch in range(start_epoch, self.epochs):

            self.model.train()
            epoch_loss = 0

            for patches, labels in tqdm(self.train_loader):

                patches = patches.to(self.device)
                labels = labels.to(self.device)

                optimizer.zero_grad()

                outputs = self.model(patches).flatten()
                loss = criterion(outputs, labels)

                loss.backward()
                optimizer.step()

                epoch_loss += loss.item()

            avg_loss = epoch_loss / len(self.train_loader)
            print(f"Epoch {epoch+1}/{self.epochs}, Loss = {avg_loss:.4f}")

            # Save checkpoint after each epoch
            if checkpoint_dir:
                torch.save({
                    'epoch': epoch,
                    'model_state': self.model.state_dict(),
                    'optimizer_state': optimizer.state_dict(),
                    'loss': avg_loss
                }, checkpoint_path)
                print(f"Checkpoint saved: epoch {epoch+1}")

    def load_model(self, path):

        self.model = torch.load(path, map_location=self.device)
        self.model.to(self.device)


        print("Model loaded from:", path)

    # ---------------------------------------------------
    # 4️⃣ Evaluation
    # ---------------------------------------------------

    def evaluate(self):

        from sklearn.metrics import (
            roc_auc_score,
            accuracy_score,
            confusion_matrix,
            classification_report,
            roc_curve
        )

        self.model.eval()

        all_probs = []
        all_labels = []

        with torch.no_grad():
            for patches, labels in tqdm(self.test_loader):

                patches = patches.to(self.device)
                labels = labels.to(self.device)

                outputs = self.model(patches).flatten()
                probs = torch.sigmoid(outputs)

                all_probs.extend(probs.cpu().numpy())
                all_labels.extend(labels.cpu().numpy())

        all_probs = np.array(all_probs)
        all_labels = np.array(all_labels)

        # -----------------------------
        # 1️⃣ Compute AUC correctly
        # -----------------------------
        auc = roc_auc_score(all_labels, all_probs)

        # -----------------------------
        # 2️⃣ Find best threshold (Youden J)
        # -----------------------------
        fpr, tpr, thresholds = roc_curve(all_labels, all_probs)
        youden = tpr - fpr
        best_idx = np.argmax(youden)
        best_threshold = thresholds[best_idx]

        # Predictions with optimal threshold
        best_preds = (all_probs > best_threshold).astype(float)

        best_acc = accuracy_score(all_labels, best_preds)

        # Also compute default 0.5 threshold for comparison
        default_preds = (all_probs > 0.5).astype(float)
        default_acc = accuracy_score(all_labels, default_preds)

        print("\n========== MODEL EVALUATION ==========")
        print("AUC:", auc)

        print("\n--- Threshold Comparison ---")
        print("Default threshold (0.5) accuracy:", default_acc)
        print("Optimal threshold:", best_threshold)
        print("Accuracy with optimal threshold:", best_acc)

        print("\nConfusion Matrix (Optimal Threshold):")
        print(confusion_matrix(all_labels, best_preds))

        print("\nClassification Report (Optimal Threshold):")
        print(
            classification_report(
            all_labels,
            best_preds,
            target_names=['No deforestation', 'Deforestation']
        ))

        print("=======================================\n")

        return best_threshold

    # ---------------------------------------------------
    # 5️⃣ Save Model
    # ---------------------------------------------------

    def save_model(self,
 path):

        torch.save(self.model, path)
        print("Model saved to:", path)








'''
Functions to produce visualizations
