class DeforestationVisualization:
    """
    Class for visualizing deforestation predictions.

    Includes:
    - Binary prediction map
    - Probability map
    - Confusion metrics
    - New deforestation metrics (22→23)
    - Layered visualization
    """

    def __init__(
        self,
        preds_asset_id,
        truth_2023_asset_id,
        truth_2022_asset_id,
        year=None,
        year2=None
    ):

        self.year = str(year)
        self.year2 = str(year2)

        # Load assets
        self.preds = ee.FeatureCollection(preds_asset_id)
        self.truth23 = ee.FeatureCollection(truth_2023_asset_id)
        self.truth22 = ee.FeatureCollection(truth_2022_asset_id)

        # Prepare merged dataset once
        self.full_data = self._prepare_joined_dataset()


    # -------------------------------------------------
    # MERGE EVERYTHING
    # -------------------------------------------------

    def _prepare_joined_dataset(self):

        join = ee.Join.inner()
        filter_eq = ee.Filter.equals(
            leftField='grid_id',
            rightField='grid_id'
        )

        # Join predictions with 2023 truth
        joined_23 = join.apply(self.preds, self.truth23, filter_eq)

        def merge_23(f):
            left = ee.Feature(f.get('primary'))
            right = ee.Feature(f.get('secondary'))
            return left.copyProperties(right)

        data_2023 = ee.FeatureCollection(joined_23.map(merge_23))

        # Join with 2022 truth
        joined_22 = join.apply(data_2023, self.truth22, filter_eq)

        def merge_22(f):
            left = ee.Feature(f.get('primary'))
            right = ee.Feature(f.get('secondary'))
            return left.copyProperties(right)

        merged = ee.FeatureCollection(joined_22.map(merge_22))

        year = self.year
        year2 = self.year2

        cleaned = merged.filter(
    ee.Filter.And(
        ee.Filter.notNull([
            'pred_defor',
            'defor_' + year,
            'defor_' + year2
        ])
    )
)

        def add_metrics(feature):
            pred = ee.Number(feature.get('pred_defor'))
            true23 = ee.Number(feature.get('defor_' + year))
            true22 = ee.Number(feature.get('defor_' + year2))

            changed = true23.subtract(true22).eq(1)

            correct_prediction = pred.eq(1).And(true23.eq(1))
            correct_predict_new = pred.eq(1).And(changed)

            tp = pred.eq(1).And(true23.eq(1)).int()
            tn = pred.eq(0).And(true23.eq(0)).int()
            fp = pred.eq(1).And(true23.eq(0)).int()
            fn = pred.eq(0).And(true23.eq(1)).int()

            return feature.set({
                'predicted_defor': pred,
                'changed_22_23': changed,
                'correct_prediction': correct_prediction,
                'correct_predict_new': correct_predict_new,
                'TP': tp,
                'TN': tn,
                'FP': fp,
                'FN': fn
            })

        return cleaned.map(add_metrics)


    # -------------------------------------------------
    # METRICS
    # -------------------------------------------------

    def print_confusion_metrics(self):

        sums = self.full_data.reduceColumns(
            ee.Reducer.sum().repeat(4),
            ['TP', 'TN', 'FP', 'FN']
        ).getInfo()['sum']

        tp, tn, fp, fn = sums
        total = tp + tn + fp + fn

        acc = (tp + tn) / total if total != 0 else float('nan')
        precision = tp / (tp + fp) if (tp + fp) != 0 else float('nan')
        recall = tp / (tp + fn) if (tp + fn) != 0 else float('nan')
        f1 = (
            2 * precision * recall / (precision + recall)
            if (precision + recall) != 0 else float('nan')
        )

        print("\nYear:", self.year)
        print("TP, TN, FP, FN =", tp, tn, fp, fn)
        print("Accuracy =", acc)
        print("Precision =", precision)
        print("Recall =", recall)
        print("F1 =", f1)

        return {
            "TP": tp,
            "TN": tn,
            "FP": fp,
            "FN": fn,
            "Accuracy": acc,
            "Precision": precision,
            "Recall": recall,
            "F1": f1
        }


    def print_deforestation_metrics(self):

        sums = self.full_data.reduceColumns(
            ee.Reducer.sum().repeat(4),
            [
                'changed_22_23',
                'predicted_defor',
                'correct_prediction',
                'correct_predict_new'
            ]
        ).getInfo()['sum']

        print("\nYear:", self.year)
        print("New deforested cells 22→23:", sums[0])
        print("Predicted deforested cells:", sums[1])
        print("Correctly predicted deforestation:", sums[2])
        print("Correctly predicted NEW deforestation:", sums[3])

        return {
            "New_Deforested_22_23": sums[0],
            "Total_Predicted": sums[1],
            "Correct_Predicted": sums[2],
            "Correct_Predicted_New": sums[3]
        }


    # -------------------------------------------------
    # MAPS
    # -------------------------------------------------

    def map_binary_predictions(self, zoom=9):

        pred_image = self.full_data.reduceToImage(
            properties=["predicted_defor"],
            reducer=ee.Reducer.first()
        )

        vis_params = {
            "min": 0,
            "max": 1,
            "palette": ["00FF00", "FF0000"]
        }

        Map = geemap.Map(basemap='CartoDB.DarkMatter')
        Map.centerObject(self.full_data, zoom)
        Map.addLayer(pred_image, vis_params, "Predicted Deforestation")

        return Map

    def map_probability(self, zoom=9):
        """
        Creates interactive EE map for predicted probabilities.
        """

        prob_image = self.full_data.reduceToImage(
            properties=["prob_defor"],
            reducer=ee.Reducer.first()
        )

        vis_params = {
            "min": 0,
            "max": 1,
            "palette": ["00FF00", "FFFF00", "FF0000"]
        }

        Map = geemap.Map(basemap='CartoDB.DarkMatter')
        Map.centerObject(self.full_data, zoom)
        Map.addLayer(prob_image, vis_params, "Deforestation Probability")

        # True new deforestation
        empty = ee.Image().byte()
        changed_fc = self.full_data.filter(
            ee.Filter.eq('changed_22_23', 1)
        )
        Map.addLayer(
            empty.paint(changed_fc, 1,2),
            {'palette': ['red']},
            'New Deforestation 22→23')

        return Map


    def map_deforestation_layers(self, zoom=9):

        Map = geemap.Map(basemap='CartoDB.DarkMatter')
        aoi = self.full_data.geometry()
        Map.centerObject(aoi, zoom)

        # AOI in white
        Map.addLayer(aoi.bounds(), {'color': 'white'}, 'AOI Boundary')

        empty = ee.Image().byte()

        # All predictions
        all_fc = self.full_data.filter(
            ee.Filter.eq('predicted_defor', 1)
        )
        Map.addLayer(
            empty.paint(all_fc, 1),
            {'palette': ['#964B00']},
            'All Predictions'
        )

        # True new deforestation
        changed_fc = self.full_data.filter(
            ee.Filter.eq('changed_22_23', 1)
        )
        Map.addLayer(
            empty.paint(changed_fc, 1),
            {'palette': ['red']},
            'New Deforestation 22→23'
        )

        # Correct predictions
        correct_fc = self.full_data.filter(
            ee.Filter.eq('correct_prediction', 1)
        )
        Map.addLayer(
            empty.paint(correct_fc, 1),
            {'palette': ['yellow']},
            'Correct Predictions'
        )

        # Correct NEW predictions
        new_fc = self.full_data.filter(
            ee.Filter.eq('correct_predict_new', 1)
        )
        Map.addLayer(
            empty.paint(new_fc, 1),
            {'palette': ['green']},
            'Correct NEW Predictions'
        )

        return Map
